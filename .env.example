# Copy to .env and fill in values before running podman-compose

# ClickHouse — port-forward: oc port-forward svc/clickhouse -n hsworkshop 18123:8123 &
CLICKHOUSE_URL=http://localhost:18123
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=

# PostgreSQL — port-forward: oc port-forward svc/postgres -n hsworkshop 15432:5432 &
POSTGRES_URL=postgresql://langfuse:@localhost:15432/langfuse

# Model — headless service, must port-forward the pod directly:
# oc port-forward -n hsworkshop $(oc get pod -n hsworkshop -l serving.kserve.io/inferenceservice=qwen35-35b-service -o name | head -1) 18080:8080 &
MODEL_URL=http://localhost:18080/v1
MODEL_NAME=qwen35-35b-service

# Langfuse (used by the guardrails proxy, not the insights backend)
LANGFUSE_HOST=https://langfuse-hsworkshop.apps.brno-hack-pool-s5z4r.aws.rh-ods.com
LANGFUSE_PUBLIC_KEY=pk-lf-
LANGFUSE_SECRET_KEY=sk-lf-

# How often (seconds) the SSE stream pushes updates to the frontend
SSE_INTERVAL_SECONDS=30
